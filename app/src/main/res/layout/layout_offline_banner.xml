<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/offline_background"
    android:gravity="center"
    android:minHeight="@dimen/offline_banner_height"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp">

    <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:contentDescription="@string/content_desc_offline"
        android:src="@drawable/ic_no_wifi"
        app:tint="@color/offline_text" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/offline_message"
        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
        android:textColor="@color/offline_text"
        android:fontFamily="sans-serif-medium" />

</LinearLayout>
